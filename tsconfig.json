{
  "compilerOptions": {
    "target": "ES2020",                        // JavaScript version output
    "module": "CommonJS",                      // Node uses CommonJS modules
    "rootDir": "./src",                        // Source folder
    "outDir": "./dist",                        // Compiled JS output
    "strict": true,                            // Enable all strict type-checking options
    "esModuleInterop": true,                   // For default imports from CommonJS
    "forceConsistentCasingInFileNames": true, 
    "skipLibCheck": true,                       // Skip type checks for node_modules
    "resolveJsonModule": true,                 // Allow importing JSON files
    "noImplicitAny": true,                     // Avoid implicit any types
    "moduleResolution": "node"                 // Module resolution for Node
  },
  "include": ["src/**/*"],                     // Include all TS files in src
  "exclude": ["node_modules", "dist"]          // Exclude these folders
}